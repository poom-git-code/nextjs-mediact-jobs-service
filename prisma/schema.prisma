generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
  binaryTargets   = ["native"]
}

datasource db {
  provider = "mysql"
}

model activity_logs {
  id         Int       @id @default(autoincrement())
  user_id    Int?
  action     String    @db.VarChar(255)
  module     String    @db.VarChar(100)
  ip_address String?   @db.VarChar(50)
  created_at DateTime? @default(now()) @db.Timestamp(0)
}

model ad_clicks {
  id             Int       @id @default(autoincrement())
  ad_id          Int
  ad_media_id    Int?
  timestamp      DateTime? @default(now()) @db.Timestamp(0)
  viewer_ip      String?   @db.VarChar(45)
  viewer_user_id Int?
  created_by     Int?
  updated_by     Int?
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamp(0)

  @@index([ad_media_id], map: "fk_ad_media")
}

model ad_impressions {
  id             Int       @id @default(autoincrement())
  ad_id          Int
  ad_media_id    Int?
  timestamp      DateTime? @default(now()) @db.Timestamp(0)
  viewer_ip      String?   @db.VarChar(45)
  viewer_user_id Int?
  created_by     Int?
  updated_by     Int?
  created_at     DateTime? @default(now()) @db.Timestamp(0)
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamp(0)

  @@index([ad_media_id], map: "fk_ad_media")
}

model ad_media {
  id            Int       @id @default(autoincrement())
  ad_id         Int
  media_url     String    @db.VarChar(500)
  media_type    String    @db.VarChar(50)
  media_size    Int?
  thumbnail_url String?   @db.VarChar(500)
  is_active     Boolean?  @default(true)
  created_by    Int?
  updated_by    Int?
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @updatedAt @db.Timestamp(0)
  media_name    String    @db.VarChar(50)
}

model ad_partners {
  id                   Int      @id @default(autoincrement())
  partner_type_id      Int?
  status_id            Int?
  partner_name         String   @db.VarChar(50)
  contact_name         String   @db.VarChar(50)
  email                String?  @db.VarChar(100)
  contact_email        String?  @db.VarChar(100)
  country_code         String?  @db.VarChar(10)
  phone_number         String?  @db.VarChar(20)
  contact_phone_number String?  @db.VarChar(20)
  profile_picture      String?  @db.VarChar(1024)
  tax_id               String?  @db.VarChar(50)
  created_by           Int?
  updated_by           Int?
  created_at           DateTime @default(now()) @db.DateTime(0)
  updated_at           DateTime @default(now()) @updatedAt @db.DateTime(0)
}

model ad_target_groups {
  id           Int       @id @default(autoincrement())
  ad_id        Int
  target_group String    @db.VarChar(255)
  created_by   Int?
  updated_by   Int?
  created_at   DateTime? @default(now()) @db.Timestamp(0)
  updated_at   DateTime? @default(now()) @updatedAt @db.Timestamp(0)
}

model ad_targets {
  id           Int      @id @default(autoincrement())
  ad_id        Int
  target_type  String   @db.VarChar(50)
  target_value String   @db.VarChar(255)
  is_active    Boolean? @default(true)
  created_by   Int?
  updated_by   Int?
  created_at   DateTime @default(now()) @db.DateTime(0)
  updated_at   DateTime @default(now()) @updatedAt @db.DateTime(0)
}

model ad_type {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  description String?  @db.Text
  is_active   Boolean? @default(true)
  created_by  Int?
  updated_by  Int?
  created_at  DateTime @default(now()) @db.DateTime(0)
  updated_at  DateTime @default(now()) @updatedAt @db.DateTime(0)
}

model ad_types {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(50)
  description String?   @db.Text
  created_by  Int?
  updated_by  Int?
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamp(0)
}

model address_types {
  id          Int       @id @default(autoincrement())
  name        String    @unique(map: "name") @db.VarChar(50)
  description String?   @db.Text
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamp(0)
  created_by  Int?
  updated_by  Int?
}

model addresses {
  id               Int      @id @default(autoincrement())
  reference_id     Int
  address_type     Int?
  address_line1    String   @db.VarChar(255)
  address_line2    String?  @db.VarChar(255)
  country_code     String?  @db.VarChar(50)
  province_code    Int?
  district_code    Int?
  subdistrict_code Int?
  is_active        Boolean? @default(true)
  created_at       DateTime @default(now()) @db.DateTime(0)
  updated_at       DateTime @default(now()) @updatedAt @db.DateTime(0)
  created_by       Int?
  updated_by       Int?
  province         String?  @db.VarChar(255)
  district         String?  @db.VarChar(100)
  sub_district     String?  @db.VarChar(100)
  postal_code      String   @db.VarChar(5)
  country          String?  @db.VarChar(100)
}

model ads {
  id                  Int       @id @default(autoincrement())
  partner_id          Int
  ad_type_id          Int
  url                 String?   @db.VarChar(255)
  start_date          DateTime? @db.Date
  end_date            DateTime? @db.Date
  title               String    @db.VarChar(255)
  content             String?   @db.Text
  status              String?   @default("active") @db.VarChar(50)
  budget              Decimal   @default(0.0000) @db.Decimal(10, 4)
  used_budgets        Decimal   @default(0.0000) @db.Decimal(10, 4)
  cost_per_click      Decimal   @default(0.0000) @db.Decimal(10, 4)
  cost_per_impression Decimal   @default(0.0000) @db.Decimal(10, 4)
  created_by          Int?
  updated_by          Int?
  created_at          DateTime  @default(now()) @db.DateTime(0)
  updated_at          DateTime  @default(now()) @updatedAt @db.DateTime(0)
}

model ads_translations {
  id            Int       @id @default(autoincrement())
  ad_id         Int
  language_code String    @db.VarChar(10)
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime? @default(now()) @updatedAt @db.Timestamp(0)

  @@unique([ad_id, language_code], map: "ad_id")
}

model announcements {
  id           Int                   @id @default(autoincrement())
  title        String                @db.VarChar(255)
  message      String                @db.Text
  target_group String?               @db.Text
  priority     AnnouncementPriority? @default(normal)
  created_by   Int?
  updated_by   Int?
  created_at   DateTime?             @default(now()) @db.Timestamp(0)
  updated_at   DateTime?             @default(now()) @updatedAt @db.Timestamp(0)
}

model applicant_reviews {
  id           Int         @id @default(autoincrement())
  job_apply_id Int         @unique(map: "uk_job_apply_id")
  reviewer_id  Int?
  rating       Int         @db.TinyInt
  comment      String?     @db.VarChar(2000)
  is_active    Boolean     @default(true)
  created_at   DateTime    @default(now()) @db.DateTime(0)
  job_apply    job_applies @relation(fields: [job_apply_id], references: [id], onDelete: Cascade, map: "fk_review_to_application")
  reviewer     users?      @relation("ReviewerRelation", fields: [reviewer_id], references: [id], map: "fk_review_to_reviewer")

  @@index([is_active], map: "idx_is_active")
  @@index([reviewer_id], map: "idx_reviewer_id")
}

model approvers {
  id           Int       @id @default(autoincrement())
  user_id      Int
  username     String    @db.VarChar(50)
  email        String?   @db.VarChar(100)
  first_name   String    @db.VarChar(60)
  last_name    String    @db.VarChar(60)
  phone_number String?   @db.VarChar(20)
  is_active    Boolean   @default(true)
  created_by   Int?
  updated_by   Int?
  created_at   DateTime? @db.DateTime(0)
  updated_at   DateTime? @db.DateTime(0)
}

model audit_settings {
  id                 Int       @id @default(autoincrement())
  table_name         String    @unique(map: "table_name") @db.VarChar(100)
  auto_audit_enabled Boolean?  @default(true)
  track_select       Boolean?  @default(false)
  track_insert       Boolean?  @default(true)
  track_update       Boolean?  @default(true)
  track_delete       Boolean?  @default(true)
  exclude_columns    Json?
  created_at         DateTime? @default(now()) @db.Timestamp(0)
  updated_at         DateTime? @default(now()) @updatedAt @db.Timestamp(0)

  @@index([auto_audit_enabled], map: "idx_auto_audit_enabled")
  @@index([table_name], map: "idx_table_name")
}

model auspicious_colors {
  id         Int                 @id @default(autoincrement())
  group_id   Int
  color_name String?             @db.VarChar(50)
  colors     String              @db.Char(7)
  type       AuspiciousColorType
  created_at DateTime?           @default(now()) @db.Timestamp(0)
  created_by Int?
  updated_at DateTime?           @default(now()) @updatedAt @db.Timestamp(0)
  updated_by Int?
  creator    users?              @relation("AuspiciousColorCreator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "auspicious_colors_ibfk_1")
  updater    users?              @relation("AuspiciousColorUpdater", fields: [updated_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "auspicious_colors_ibfk_2")

  @@index([created_by], map: "created_by")
  @@index([updated_by], map: "updated_by")
}

model bonus_days {
  id           Int       @id @default(autoincrement())
  bonus_date   DateTime? @unique(map: "bonus_date") @db.Date
  weekday      Weekday?
  bonus_points Int
  description  String?   @db.VarChar(255)
  is_recurring Boolean?  @default(false)
}

model booth_events {
  id                    BigInt         @id @default(autoincrement())
  name                  String         @db.VarChar(255)
  type                  BoothEventType @default(onsite)
  start_date            DateTime       @db.DateTime(0)
  end_date              DateTime       @db.DateTime(0)
  total_stamps_required Int            @default(5)
  is_active             Boolean        @default(true)
  created_at            DateTime       @db.DateTime(0)
  updated_at            DateTime       @db.DateTime(0)
}

model booth_list {
  id             BigInt   @id @default(autoincrement())
  booth_event_id BigInt
  stamp_code     String   @unique(map: "stamp_code") @db.VarChar(100)
  booth_name     String   @db.VarChar(255)
  is_active      Boolean  @default(true)
  created_at     DateTime @db.DateTime(0)
  updated_at     DateTime @db.DateTime(0)
}

model brands {
  id              Int                   @id @default(autoincrement())
  name_th         String                @db.VarChar(255)
  name_en         String?               @db.VarChar(255)
  logo_url        String?               @db.VarChar(500)
  is_active       Boolean               @default(true)
  type_id         Int?
  created_at      DateTime?             @default(now()) @db.DateTime(0)
  updated_at      DateTime?             @default(now()) @updatedAt @db.DateTime(0)
  reward_type     checkIn_reward_types? @relation(fields: [type_id], references: [id], map: "fk_brands_to_reward_types")
  checkIn_rewards checkIn_rewards[]

  @@index([type_id], map: "idx_brand_type_id")
}

model category_master {
  id          Int           @id @default(autoincrement())
  scope       CategoryScope @default(both)
  code        String        @db.VarChar(50)
  name_th     String        @db.VarChar(255)
  name_en     String        @db.VarChar(255)
  description String?       @db.Text
  is_active   Boolean?      @default(true)
  created_by  Int?
  updated_by  Int?
  created_at  DateTime?     @default(now()) @db.DateTime(0)
  updated_at  DateTime?     @default(now()) @updatedAt @db.DateTime(0)

  @@unique([scope, code], map: "uq_scope_code")
  @@index([is_active], map: "idx_active")
}

model certifications {
  id         Int       @id @default(autoincrement())
  name_th    String    @db.VarChar(500)
  name_en    String    @db.VarChar(500)
  role_id    Int
  is_active  Boolean?  @default(true)
  created_by Int?
  updated_by Int?
  created_at DateTime? @db.DateTime(0)
  updated_at DateTime? @db.DateTime(0)
}

model sub_certifications {
  id               Int      @id @default(autoincrement())
  certification_id Int
  name_th          String   @db.VarChar(255)
  name_en          String   @db.VarChar(255)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.DateTime(0)
  updated_at       DateTime @default(now()) @updatedAt @db.DateTime(0)

  @@index([certification_id], map: "certification_id")
}

model checkIn_reward_redemptions {
  id          Int                                @id @default(autoincrement())
  user_id     Int
  reward_id   Int?
  points_used Int
  status      checkIn_reward_redemptions_status? @default(pending)
  redeemed_at DateTime?                          @default(now()) @db.Timestamp(0)
  expires_at  DateTime?                          @db.Timestamp(0)
  user        users                              @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "checkIn_reward_redemptions_ibfk_1")
  reward      checkIn_rewards?                   @relation(fields: [reward_id], references: [id], onUpdate: NoAction, map: "checkIn_reward_redemptions_ibfk_2")

  @@index([reward_id], map: "reward_id")
  @@index([user_id], map: "user_id")
}

model checkIn_reward_types {
  id              Int               @id @default(autoincrement())
  name_th         String            @db.VarChar(255)
  name_en         String            @db.VarChar(255)
  description     String?           @db.Text
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamp(0)
  updated_at      DateTime?         @default(now()) @updatedAt @db.Timestamp(0)
  created_by      Int?
  updated_by      Int?
  brands          brands[]
  checkIn_rewards checkIn_rewards[]
}

model checkIn_rewards {
  id              Int                          @id @default(autoincrement())
  title           String                       @db.VarChar(200)
  description     String?                      @db.Text
  conditions      String?                      @db.Text
  image_url       String?                      @db.VarChar(1024)
  redeem_code     String?                      @db.VarChar(255)
  points_required Int
  expiry_date     DateTime?                    @db.Date
  is_active       Boolean?                     @default(true)
  stock_quantity  Int?                         @default(-1)
  created_at      DateTime?                    @default(now()) @db.Timestamp(0)
  type_id         Int?
  brand_id        Int?
  status_redeem   String                       @default("available") @db.VarChar(20)
  redeem_date     DateTime?                    @db.DateTime(0)
  created_by      Int?
  updated_by      Int?
  updated_at      DateTime?                    @default(now()) @updatedAt @db.DateTime(0)
  redemptions     checkIn_reward_redemptions[]
  reward_type     checkIn_reward_types?        @relation(fields: [type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reward_type")
  brand           brands?                      @relation(fields: [brand_id], references: [id], map: "fk_rewards_to_brands")

  @@index([brand_id], map: "idx_brand_id")
  @@index([type_id], map: "fk_reward_type")
}

model check_in_logs {
  id          Int       @id @default(autoincrement())
  user_id     Int
  action      String?   @db.VarChar(50)
  description String?   @db.VarChar(500)
  metadata    Json?
  created_at  DateTime? @default(now()) @db.DateTime(0)
  user        users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "check_in_logs_ibfk_1")

  @@index([user_id], map: "user_id")
}

model content_category {
  id          Int       @id @default(autoincrement())
  name        String    @unique(map: "name") @db.VarChar(255)
  description String?   @db.Text
  is_active   Boolean?  @default(true)
  sort_order  Int?      @default(0)
  created_at  DateTime? @default(now()) @db.Timestamp(0)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamp(0)
  created_by  Int?
  updated_by  Int?
}

model content_stats {
  id           Int         @id @default(autoincrement()) @db.UnsignedInt
  content_id   Int         @db.UnsignedInt
  content_type ContentType
  views        Int         @default(0) @db.UnsignedInt
  likes        Int         @default(0) @db.UnsignedInt
  dislikes     Int         @default(0) @db.UnsignedInt
  created_at   DateTime    @default(now()) @db.DateTime(0)
  updated_at   DateTime    @default(now()) @updatedAt @db.DateTime(0)

  @@unique([content_id, content_type], map: "content_id")
}

model credit_approval_logs {
  id            Int                  @id @default(autoincrement())
  credit_log_id Int?
  approver_id   Int
  approved_at   DateTime?            @db.DateTime(0)
  status        CreditApprovalStatus @default(approved)
  remark        String?              @db.Text
  created_by    Int?
  updated_by    Int?
  created_at    DateTime?            @db.DateTime(0)
  updated_at    DateTime?            @db.DateTime(0)
  credit_log    credit_logs?         @relation(fields: [credit_log_id], references: [id], map: "credit_approval_logs_ibfk_1")

  @@index([credit_log_id], map: "credit_log_id")
}

model credit_logs {
  id              Int                    @id @default(autoincrement())
  credit_id       Int
  reference_id    Int?
  change          Decimal                @db.Decimal(10, 4)
  type            String                 @db.VarChar(50)
  description     String                 @db.Text
  created_by      Int?
  updated_by      Int?
  created_at      DateTime?              @default(now()) @db.DateTime(0)
  updated_at      DateTime?              @default(now()) @updatedAt @db.DateTime(0)
  approval_logs   credit_approval_logs[]
  credit_requests credit_requests[]
}

model credit_requests {
  id            Int                 @id @default(autoincrement())
  credit_id     Int
  credit_log_id Int?
  amount        Decimal             @db.Decimal(10, 4)
  request_type  CreditRequestType   @default(topup)
  status        CreditRequestStatus @default(pending)
  requested_by  Int
  approved_by   Int?
  requested_at  DateTime?           @db.DateTime(0)
  approved_at   DateTime?           @db.DateTime(0)
  remark        String?             @db.Text
  created_by    Int?
  updated_by    Int?
  created_at    DateTime?           @db.DateTime(0)
  updated_at    DateTime?           @db.DateTime(0)
  credit        credits             @relation(fields: [credit_id], references: [id], onDelete: NoAction, map: "credit_requests_ibfk_1")
  credit_log    credit_logs?        @relation(fields: [credit_log_id], references: [id], map: "credit_requests_ibfk_2")

  @@index([credit_id], map: "credit_id")
  @@index([credit_log_id], map: "credit_log_id")
}

model credits {
  id              Int               @id @default(autoincrement())
  user_id         Int
  total_credits   Decimal           @default(0.0000) @db.Decimal(10, 4)
  used_credits    Decimal           @default(0.0000) @db.Decimal(10, 4)
  created_by      Int?
  updated_by      Int?
  created_at      DateTime?         @db.DateTime(0)
  updated_at      DateTime?         @db.DateTime(0)
  credit_requests credit_requests[]
}

model day_off {
  id                 Int       @id @default(autoincrement())
  request_user_id    Int
  assign_user_id     Int
  day_off_date       DateTime  @db.Date
  month              Int       @db.TinyInt
  year               Int       @db.SmallInt
  schedule_master_id Int
  status             String    @db.VarChar(255)
  reason             String?   @db.Text
  approve_user_id    Int
  approve_date       DateTime? @db.Date
  approve_at         DateTime? @db.DateTime(0)
  remark             String?   @db.VarChar(255)
  revoke_remark      String?   @db.VarChar(255)
  created_by         Int?
  updated_by         Int?
  created_at         DateTime? @default(now()) @db.DateTime(0)
  updated_at         DateTime? @default(now()) @updatedAt @db.DateTime(0)
  is_deleted         Boolean   @default(false)

  @@index([request_user_id, month, year, status], map: "idx_user_month_year_status")
  @@index([request_user_id, month, year], map: "idx_user_month_year")
  @@index([request_user_id, day_off_date], map: "idx_user_date")
}

model department_category {
  id              Int       @id @default(autoincrement())
  department_id   Int
  category_id     Int
  sub_category_id Int?
  is_primary      Boolean?  @default(false)
  display_order   Int?      @default(0)
  effective_start DateTime? @db.Date
  effective_end   DateTime? @db.Date
  is_active       Boolean?  @default(true)
  created_by      Int?
  updated_by      Int?
  created_at      DateTime? @default(now()) @db.DateTime(0)
  updated_at      DateTime? @default(now()) @updatedAt @db.DateTime(0)

  @@unique([department_id, category_id, sub_category_id], map: "uq_dept_cat_sub")
  @@index([is_active], map: "idx_active")
  @@index([category_id], map: "idx_cat")
  @@index([department_id], map: "idx_dept")
  @@index([effective_start, effective_end], map: "idx_effective")
  @@index([sub_category_id], map: "idx_subcat")
}

model department_absence_limit_configs {
  id            Int         @id @default(autoincrement())
  department_id Int
  month         Int         @db.TinyInt
  is_enabled    Boolean     @default(true)
  monday        Int         @default(0)
  tuesday       Int         @default(0)
  wednesday     Int         @default(0)
  thursday      Int         @default(0)
  friday        Int         @default(0)
  saturday      Int         @default(0)
  sunday        Int         @default(0)
  created_by    Int?
  updated_by    Int?
  created_at    DateTime?   @default(now()) @db.DateTime(0)
  updated_at    DateTime?   @default(now()) @updatedAt @db.DateTime(0)
  department    departments @relation(fields: [department_id], references: [id], onDelete: Cascade, map: "fk_dept_absence_limit_config_department")

  @@unique([department_id, month], name: "uq_dept_month", map: "uq_dept_month")
  @@index([department_id], map: "idx_department_id")
}

model department_certifications {
  id               Int         @id @default(autoincrement())
  department_id    Int
  certification_id Int
  created_by       Int?
  created_at       DateTime?   @db.DateTime(0)
  department       departments @relation(fields: [department_id], references: [id], onDelete: Cascade, map: "fk_dept_cert_department")
  creator          users?      @relation("DeptCertCreator", fields: [created_by], references: [id], map: "fk_dept_cert_user")

  @@unique([department_id, certification_id], map: "uq_dept_cert")
  @@index([certification_id], map: "certification_id")
  @@index([created_by], map: "created_by")
  @@index([department_id], map: "department_id")
}

model department_operating_hours {
  id            BigInt    @id @default(autoincrement())
  department_id BigInt
  weekday       Weekday
  start_time    DateTime  @db.Time(0)
  end_time      DateTime  @db.Time(0)
  is_active     Boolean?  @default(true)
  created_by    BigInt?
  updated_by    BigInt?
  created_at    DateTime? @default(now()) @db.DateTime(0)
  updated_at    DateTime? @default(now()) @updatedAt @db.DateTime(0)
}

model department_supervisors {
