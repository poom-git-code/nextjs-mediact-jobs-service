}

model facility_packages {
  id                       Int                     @id @default(autoincrement())
  facility_id              Int
  package_id               Int
  credits_total            Int
  credits_remaining        Int
  status                   facility_package_status
  payment_reference        String?                 @db.VarChar(100)
  payment_slip_original    String?                 @db.VarChar(500)
  payment_slip_watermarked String?                 @db.VarChar(500)
  requested_by             Int?
  requested_at             DateTime?               @db.DateTime(0)
  approved_by              Int?
  approved_at              DateTime?               @db.DateTime(0)
  rejected_by              Int?
  rejected_at              DateTime?               @db.DateTime(0)
  rejection_reason         String?                 @db.Text
  activated_at             DateTime?               @db.DateTime(0)
  expires_at               DateTime?               @db.DateTime(0)
