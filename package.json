{
  "name": "mediact-jobs-service",
  "version": "1.0.29",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun run src/main.ts",
    "start:dev": "bun --watch run src/main.ts",
    "start:prod": "bun run dist/src/main.js",
    "build": "nest build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "TZ=Asia/Bangkok vitest",
    "test:cov": "TZ=Asia/Bangkok vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "vitest run --config ./test/vitest-e2e.config.ts",
    "test:jest": "jest",
    "test:jest:watch": "TZ=Asia/Bangkok jest --watch",
    "test:jest:cov": "TZ=Asia/Bangkok jest --coverage",
    "db:migration": "bunx prisma migrate dev --name init"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.971.0",
    "@fastify/compress": "^8.3.0",
    "@fastify/static": "^9.0.0",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.4.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@ssut/nestjs-sqs": "^3.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "firebase-admin": "^13.8.0",
    "ky": "^2.0.2",
    "nestjs-custom-module": "https://github.com/Mediact-Tech/nestjs-common-modules.git#v1.0.2",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.7.0",
    "unplugin-swc": "^1.5.9"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.{js,ts}",
      "!src/app/external-services/**/*.{js,ts}",
      "!src/app/controllers/**/*.{js,ts}",
      "!src/app/repositories/**/*.{js,ts}",
      "!src/app-configs/**/*.{js,ts}",
      "!src/modules/**/*.{js,ts}",
      "!src/app.module.ts",
      "!src/main.ts"
    ],
    "coverageReporters": [
      "html",
      "json"
    ],
    "coverageDirectory": "coverage",
    "testEnvironment": "node"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/testing": "^11.1.9",
    "@swc/core": "^1.7.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.7.1",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
